      "endpoint": "/api/resources?pageSize=50",
      "description": "모니터링 리소스"
    },
    {
      "id": "aria-resource-types",
      "name": "리소스 유형",
      "method": "GET",
      "endpoint": "/api/resourcetypes",
      "description": "리소스 유형 목록"
    },
    {
      "id": "aria-alerts",
      "name": "경고 목록",
      "method": "GET",
      "endpoint": "/api/alerts?activeAlertsOnly=true&pageSize=50",
      "description": "활성 경고"
    },
    {
      "id": "aria-alerts-critical",
      "name": "긴급 경고",
      "method": "GET",
      "endpoint": "/api/alerts?alertCriticality=CURRENT&severity=CRITICAL",
      "description": "긴급(Critical) 경고"
