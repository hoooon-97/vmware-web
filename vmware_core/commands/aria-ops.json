{
  "category": "Aria Ops",
  "description": "VMware Aria Operations (vRealize Operations) 관리",
  "connectionType": "api",
  "baseUrl": "https://{host}/suite-api",
  "commands": [
    {
      "id": "aria-adapters",
      "name": "어댑터 종류",
      "method": "GET",
      "endpoint": "/api/adapterkinds",
      "description": "등록된 어댑터 종류"
    },
    {
      "id": "aria-resources",
      "name": "리소스 목록",
